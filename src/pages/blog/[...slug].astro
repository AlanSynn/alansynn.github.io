---
import Base from '@/layouts/Base.astro';
import Toc from '@/components/Toc.astro';
import { getCollection, render } from 'astro:content';
import { site } from '@/lib/data';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const tags = (post.data.tags ?? []) as string[];
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
// Chip text title-cases the kebab slug (participatory-design → "Participatory
// Design") for display; the raw slug still drives the ?tag= link.
const tagLabel = (t: string) =>
  t
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');

// Reply email obfuscation — same as Socials.astro (base64 halves, JS-decoded).
const [mailUser, mailDomain] = site.email.split('@');
const enc = (s: string) => Buffer.from(s, 'utf-8').toString('base64');
const replySubject = encodeURIComponent('Re: ' + post.data.title);
---

<Base title={post.data.title} contained={false}>
  <article class="post">
    <div class="post-layout">
      <Toc />
      <div class="post-body">
        <nav class="post-crumbs" aria-label="Back to posts">
          <a href="/blog"><span aria-hidden="true">←</span> blog</a>
        </nav>
        <header class="post-header">
          <h1>{post.data.title}</h1>
          <div class="post-meta">
            <span class="meta-core">
              <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              {post.data.author && <span>by {post.data.author}</span>}
            </span>
            {
              tags.length > 0 && (
                <span class="meta-tags">
                  {tags.map((t) => (
                    <a class="tag-chip" href={`/blog?tag=${encodeURIComponent(t)}`}>
                      #{tagLabel(t)}
                    </a>
                  ))}
                </span>
              )
            }
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>

        <a class="back-link" href="/blog">← All posts</a>

        <section class="reply">
          <p>
            Thoughts? <a
              class="reply__email"
              href="#"
              data-u={enc(mailUser)}
              data-d={enc(mailDomain)}
              data-s={enc(replySubject)}>Reply by email</a
            >.
          </p>
        </section>

        <p class="license-note">
          Licensed under <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/"
            >CC BY-NC-ND 4.0</a
          >
        </p>
      </div>
    </div>
  </article>
  <script is:inline>
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a.reply__email[data-u]');
      if (!a) return;
      e.preventDefault();
      try {
        var u = atob(a.getAttribute('data-u'));
        var d = atob(a.getAttribute('data-d'));
        var s = a.getAttribute('data-s');
        window.location.href = 'mailto:' + u + '@' + d + (s ? '?subject=' + atob(s) : '');
      } catch (err) {
        /* noop */
      }
    });
  </script>
</Base>

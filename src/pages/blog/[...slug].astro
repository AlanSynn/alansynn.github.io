---
import Base from '@/layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { site } from '@/lib/data';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const tags = (post.data.tags ?? []) as string[];
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base title={post.data.title}>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
        {post.data.author && <span>by {post.data.author}</span>}
        {tags.length > 0 && <span>{tags.join(' · ')}</span>}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    {tags.length > 0 && (
      <ul class="tag-list">
        {tags.map((t) => <li><a href="/blog">#{t}</a></li>)}
      </ul>
    )}

    <a class="back-link" href="/blog">← All posts</a>

    <section class="reply">
      <p>Thoughts? Reply by email — <a href={`mailto:${site.email}?subject=${encodeURIComponent('Re: ' + post.data.title)}`}>{site.email}</a>.</p>
    </section>
  </article>
</Base>

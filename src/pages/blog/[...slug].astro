---
import Base from '@/layouts/Base.astro';
import Toc from '@/components/Toc.astro';
import { getCollection, render } from 'astro:content';
import { site } from '@/lib/data';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const tags = (post.data.tags ?? []) as string[];
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });

// Obfuscate the reply address the same way Socials.astro does (base64 halves,
// JS-decoded) so the raw email never appears in the served HTML.
const [mailUser, mailDomain] = site.email.split('@');
const enc = (s: string) => Buffer.from(s, 'utf-8').toString('base64');
const replySubject = encodeURIComponent('Re: ' + post.data.title);
---

<Base title={post.data.title} contained={false}>
  <article class="post">
    <div class="post-layout">
      <Toc />
      <div class="post-body">
        <nav class="post-crumbs" aria-label="Back to posts">
          <a href="/blog"><span aria-hidden="true">←</span> blog</a>
        </nav>
        <header class="post-header">
          <h1>{post.data.title}</h1>
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
            {post.data.author && <span>by {post.data.author}</span>}
            {tags.length > 0 && <span>{tags.join(' · ')}</span>}
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>

        {
          tags.length > 0 && (
            <ul class="tag-list">
              {tags.map((t) => (
                <li>
                  <a href="/blog">#{t}</a>
                </li>
              ))}
            </ul>
          )
        }

        <a class="back-link" href="/blog">← All posts</a>

        <section class="reply">
          <p>
            Thoughts? <a
              class="reply__email"
              href="#"
              data-u={enc(mailUser)}
              data-d={enc(mailDomain)}
              data-s={enc(replySubject)}>Reply by email</a
            >.
          </p>
        </section>
      </div>
    </div>
  </article>
  <script is:inline>
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a.reply__email[data-u]');
      if (!a) return;
      e.preventDefault();
      try {
        var u = atob(a.getAttribute('data-u'));
        var d = atob(a.getAttribute('data-d'));
        var s = a.getAttribute('data-s');
        window.location.href = 'mailto:' + u + '@' + d + (s ? '?subject=' + atob(s) : '');
      } catch (err) {
        /* noop */
      }
    });
  </script>
</Base>

---
import Base from '@/layouts/Base.astro';
import Markdown from '@/components/Markdown.astro';
import CompactPub from '@/components/CompactPub.astro';
import Socials from '@/components/Socials.astro';
import Timeline from '@/components/Timeline.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import NewsList from '@/components/NewsList.astro';
import {
  site, researchInterests, getPapers, experience, education,
  honors, teaching, activities,
} from '@/lib/data';
import { getCollection } from 'astro:content';

// One page = the whole CV. Scroll-only, no nav.
const papers = getPapers();
// Curated "Selected" for a Graphics/HCI scanner (2 CHI, NeurIPS demo, 2 first-author systems).
const highlighted = ['synn2026motionsmith', 'yu2025tangible', 'ahn2021nips', 'synn2023distributed'];
const selectedPubs = papers.filter((p) => highlighted.includes(p.key));
const otherPubs = papers.filter((p) => !highlighted.includes(p.key));

const projects = (await getCollection('projects')).sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0));

// News: newest first, capped to the 8 most recent on the homepage.
const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);

const bio = researchInterests.statements[0];

// Email obfuscation for the inline "Say hi" link (base64 halves, JS-decoded
// mailto on click — same pattern as Socials.astro, caught by its handler).
const [mailUser, mailDomain] = site.email.split('@');
const enc = (s: string) => Buffer.from(s, 'utf-8').toString('base64');
---
<Base>
  {/* ---- Profile (text left, photo right) ---- */}
  <section id="profile" class="profile">
    <div class="profile__text">
      <h1>{site.name}</h1>
      <p class="profile__role">{site.title} · <a href="https://ic.gatech.edu">School of Interactive Computing</a>, <a href="https://www.gatech.edu">Georgia Tech</a></p>
      <p class="profile__advisors">Advised by <a href="https://www.cc.gatech.edu/people/hyunjoo-oh">Prof. HyunJoo Oh</a> &amp; <a href="https://faculty.cc.gatech.edu/~sha9/">Prof. Sehoon Ha</a></p>
      <div class="profile__bio"><Markdown content={bio} /></div>
      <Socials />
    </div>
    <div class="profile__portrait">
      <img
        class="profile__photo"
        src="/profile-photo.webp"
        alt={`Portrait of ${site.name}`}
        width="336"
        height="420"
        loading="eager"
      />
    </div>
  </section>

  {/* ---- News ---- */}
  <section id="news">
    <h2 class="home-head">News</h2>
    <NewsList items={news} />
  </section>

  {/* ---- Publications (Selected + All) ---- */}
  <section id="publications">
    <h2 class="home-head">Publications</h2>
    <div class="cpubs">
      {selectedPubs.map((p) => <CompactPub paper={p} />)}
    </div>
    {otherPubs.length > 0 && (
      <details class="all-pubs">
        <summary>All publications ({otherPubs.length} more)</summary>
        <div class="cpubs">
          {otherPubs.map((p) => <CompactPub paper={p} />)}
        </div>
      </details>
    )}
  </section>

  {/* ---- Projects ---- */}
  <section id="projects">
    <h2 class="home-head">Projects</h2>
    <div class="project-grid">{projects.map((p) => <ProjectCard project={p} />)}</div>
  </section>

  {/* ---- Experience ---- */}
  <section id="experience">
    <h2 class="home-head">Experience</h2>
    <Timeline items={experience} />
  </section>

  {/* ---- Education ---- */}
  <section id="education">
    <h2 class="home-head">Education</h2>
    <Timeline items={education} />
  </section>

  {/* ---- Honors ---- */}
  <section id="honors">
    <h2 class="home-head">Honors &amp; Awards</h2>
    {honors.map((g: { group: string; items: string[] }) => (
      <div class="honor-group">
        <div class="honor-group__label">{g.group}</div>
        <ul class="honor-group__list">
          {g.items.map((it: string) => <li><Markdown content={it} /></li>)}
        </ul>
      </div>
    ))}
  </section>

  {/* ---- Teaching ---- */}
  <section id="teaching">
    <h2 class="home-head">Teaching</h2>
    <Timeline items={teaching} />
  </section>

  {/* ---- Activities & Service ---- */}
  <section id="service">
    <h2 class="home-head">Activities &amp; Service</h2>
    <Timeline items={activities} />
  </section>

  {/* ---- Contact ---- */}
  <section id="contact">
    <h2 class="home-head">Contact</h2>
    <p>I'm always up for a coffee chat about research, collaborations, internships, or wherever graphics meets design. <a href="#" data-u={enc(mailUser)} data-d={enc(mailDomain)}>Say hi</a> anytime.</p>
  </section>
</Base>

<style>
  .profile__advisors {
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin-bottom: var(--space-4);
  }
  .profile__portrait { position: relative; }
  .profile__portrait .profile__photo { position: relative; z-index: 1; }
  .all-pubs { margin-top: var(--space-5); }
  .all-pubs > summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--step--1);
    color: var(--accent);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--hairline);
  }
  .all-pubs > summary::-webkit-details-marker { display: none; }
  .all-pubs[open] > summary { border-bottom: 1px solid var(--hairline); margin-bottom: var(--space-3); }
  @media (max-width: 640px) {
    .profile__portrait { order: -1; }   /* photo first on mobile */
  }
</style>

---
import Base from '@/layouts/Base.astro';
import Markdown from '@/components/Markdown.astro';
import CompactPub from '@/components/CompactPub.astro';
import Socials from '@/components/Socials.astro';
import Timeline from '@/components/Timeline.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import ResearchStatement from '@/components/ResearchStatement.astro';
import CouplerCurve from '@/components/CouplerCurve.astro';
import {
  site, researchInterests, getPapers, experience, education,
  honors, teaching, activities,
} from '@/lib/data';
import { getCollection } from 'astro:content';

// One page = the whole CV. Scroll-only, no nav.
const papers = getPapers();
// Curated "Selected" for a Graphics/HCI scanner (2 CHI, NeurIPS demo, 2 first-author systems).
const highlighted = ['synn2026motionsmith', 'yu2025tangible', 'ahn2021nips', 'synn2023distributed', 'synn2021mbs'];
const selectedPubs = papers.filter((p) => highlighted.includes(p.key));
const otherPubs = papers.filter((p) => !highlighted.includes(p.key));

const projects = (await getCollection('projects')).sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0));
const researchProjects = projects.filter((p) => p.data.category === 'research');
const engineeringProjects = projects.filter((p) => p.data.category === 'work');

const bio = researchInterests.statements[0];
---
<Base>
  {/* ---- Profile (text left, photo right) ---- */}
  <section id="profile" class="profile">
    <div class="profile__text">
      <h1>{site.name}</h1>
      <p class="profile__role">{site.title} · {site.affiliation}</p>
      <p class="profile__advisors">Advised by <strong>Prof. HyunJoo Oh</strong> &amp; <strong>Prof. Sehoon Ha</strong> · School of Interactive Computing</p>
      <div class="profile__bio"><Markdown content={bio} /></div>
      <Socials />
    </div>
    <div class="profile__portrait">
      <CouplerCurve class="profile__coupler" />
      <img
        class="profile__photo"
        src="/profile-photo.webp"
        alt={`Portrait of ${site.name}`}
        width="336"
        height="420"
        loading="eager"
      />
    </div>
  </section>

  {/* ---- Research (interests lead is in the profile bio; here the full statement) ---- */}
  <section id="research" data-reveal>
    <h2 class="home-head">Research</h2>
    <ResearchStatement />
  </section>

  {/* ---- Publications (Selected + All) ---- */}
  <section id="publications" data-reveal>
    <h2 class="home-head">Publications</h2>
    <div class="cpubs">
      {selectedPubs.map((p) => <CompactPub paper={p} />)}
    </div>
    {otherPubs.length > 0 && (
      <details class="all-pubs">
        <summary>All publications ({otherPubs.length} more)</summary>
        <div class="cpubs">
          {otherPubs.map((p) => <CompactPub paper={p} />)}
        </div>
      </details>
    )}
  </section>

  {/* ---- Projects ---- */}
  <section id="projects" data-reveal>
    <h2 class="home-head">Projects</h2>
    {researchProjects.length > 0 && (
      <>
        <h3 class="subhead">Research</h3>
        <div class="project-grid">{researchProjects.map((p) => <ProjectCard project={p} />)}</div>
      </>
    )}
    {engineeringProjects.length > 0 && (
      <>
        <h3 class="subhead">Selected engineering</h3>
        <div class="project-grid">{engineeringProjects.map((p) => <ProjectCard project={p} />)}</div>
      </>
    )}
  </section>

  {/* ---- Experience ---- */}
  <section id="experience" data-reveal>
    <h2 class="home-head">Experience</h2>
    <Timeline items={experience} />
  </section>

  {/* ---- Education ---- */}
  <section id="education" data-reveal>
    <h2 class="home-head">Education</h2>
    <Timeline items={education} />
  </section>

  {/* ---- Honors ---- */}
  <section id="honors" data-reveal>
    <h2 class="home-head">Honors &amp; Awards</h2>
    {honors.map((g: { group: string; items: string[] }) => (
      <div class="honor-group">
        <div class="honor-group__label">{g.group}</div>
        <ul class="honor-group__list">
          {g.items.map((it: string) => <li><Markdown content={it} /></li>)}
        </ul>
      </div>
    ))}
  </section>

  {/* ---- Teaching ---- */}
  <section id="teaching" data-reveal>
    <h2 class="home-head">Teaching</h2>
    <Timeline items={teaching} />
  </section>

  {/* ---- Activities & Service ---- */}
  <section id="service" data-reveal>
    <h2 class="home-head">Activities &amp; Service</h2>
    <Timeline items={activities} />
  </section>

  {/* ---- Contact ---- */}
  <section id="contact" data-reveal>
    <h2 class="home-head">Contact</h2>
    <p>Open to faculty conversations, research collaborations, and intern hosting on generative design, computational fabrication, and HCI.</p>
    <p><a class="contact-mail" href={`mailto:${site.email}`}>{site.email}</a></p>
  </section>
</Base>

<style>
  .profile__advisors {
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin-bottom: var(--space-4);
  }
  .profile__portrait { position: relative; }
  .profile__coupler {
    position: absolute;
    inset: -14px -16px -8px -8px;
    width: calc(100% + 24px);
    height: calc(100% + 22px);
    color: var(--accent);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }
  .profile__portrait .profile__photo { position: relative; z-index: 1; }
  .subhead {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
    margin: var(--space-5) 0 var(--space-3);
  }
  .subhead:first-of-type { margin-top: 0; }
  .all-pubs { margin-top: var(--space-5); }
  .all-pubs > summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--accent);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--hairline);
  }
  .all-pubs > summary::-webkit-details-marker { display: none; }
  .all-pubs[open] > summary { border-bottom: 1px solid var(--hairline); margin-bottom: var(--space-3); }
  .contact-mail { font-family: var(--font-mono); font-size: var(--step-1); color: var(--accent); }
  @media (max-width: 640px) {
    .profile__portrait { order: -1; }   /* photo first on mobile */
  }
</style>

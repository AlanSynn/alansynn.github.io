---
import Base from '@/layouts/Base.astro';
import Markdown from '@/components/Markdown.astro';
import CompactPub from '@/components/CompactPub.astro';
import Socials from '@/components/Socials.astro';
import Timeline from '@/components/Timeline.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import NewsList from '@/components/NewsList.astro';
import RobotLegs from '@/components/RobotLegs.astro';
import {
  site,
  researchInterests,
  getPapers,
  experience,
  education,
  honors,
  teaching,
  activities,
  newsItems,
  entryVisible,
} from '@/lib/data';
import { getCollection } from 'astro:content';

// One page = the whole CV. Scroll-only, no nav.
const papers = getPapers();
// Featured = the handful surfaced at the top of #publications; the rest collapse
// behind "All publications". Driven by the `featured` flag in content/papers.bib.
// (`selected` in papers.bib is PDF-only — which papers the resume/CV prints.)
const selectedPubs = papers.filter((p) => p.featured);
const otherPubs = papers.filter((p) => !p.featured);

// Projects = work/engineering only. Research (papers) lives in #publications via
// papers.bib — the category filter enforces the separation so a 'research' entry
// can never leak into the projects grid.
const projects = (await getCollection('projects'))
  .filter((p) => p.data.category !== 'research')
  .sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0));

// News: newest first, capped to the 8 most recent on the homepage. Sourced from
// the single content/news.yaml list (validated in lib/data.ts).
const news = [...newsItems].sort((a, b) => b.date.valueOf() - a.date.valueOf()).slice(0, 8);

// Render the full statements array (one <p> per statement) so the bio can be a
// multi-paragraph profile, not just the first entry.
const bio = researchInterests.statements.join('\n\n');

// Email obfuscation for the inline "Say hi" link (base64 halves, JS-decoded
// mailto on click — same pattern as Socials.astro, caught by its handler).
const [mailUser, mailDomain] = site.email.split('@');
const enc = (s: string) => Buffer.from(s, 'utf-8').toString('base64');
---

<Base>
  {/* ---- Profile (text left, photo right) ---- */}
  <section id="profile" class="profile">
    <div class="profile__text">
      <h1>{site.name}</h1>
      <p class="profile__role">
        {site.title} ·{' '}
        {
          site.department && site.department_url && (
            <Fragment>
              <a href={site.department_url}>{site.department}</a>,{' '}
            </Fragment>
          )
        }
        <a href={site.affiliation_url}>{site.affiliation}</a>
      </p>
      {
        site.advisors.length > 0 && (
          <p class="profile__advisors">
            Advised by{' '}
            {site.advisors.map((a, i) => (
              <Fragment>
                {i > 0 && (i === site.advisors.length - 1 ? ' & ' : ', ')}
                <a href={a.url}>{a.name}</a>
              </Fragment>
            ))}
          </p>
        )
      }
      <div class="profile__bio"><Markdown content={bio} /></div>
      <Socials />
    </div>
    <div class="profile__portrait">
      <img
        class="profile__photo"
        src="/profile-photo.webp"
        alt={`Portrait of ${site.name}`}
        width="336"
        height="420"
        loading="eager"
      />
      <RobotLegs zone="photo" />
    </div>
  </section>

  {/* ---- News ---- */}
  <section id="news">
    <h2 class="home-head">News</h2>
    <NewsList items={news} />
  </section>

  {/* ---- Publications (Selected + All) ---- */}
  <section id="publications">
    <h2 class="home-head">Publications</h2>
    <div class="cpubs">
      {selectedPubs.map((p) => <CompactPub paper={p} />)}
    </div>
    {
      otherPubs.length > 0 && (
        <details class="all-pubs">
          <summary>All publications ({otherPubs.length} more)</summary>
          <div class="cpubs">
            {otherPubs.map((p) => (
              <CompactPub paper={p} />
            ))}
          </div>
        </details>
      )
    }
  </section>

  {/* ---- Projects ---- */}
  <section id="projects">
    <h2 class="home-head">Projects</h2>
    <div class="project-grid">{projects.map((p) => <ProjectCard project={p} />)}</div>
  </section>

  {/* ---- Experience ---- */}
  <section id="experience">
    <h2 class="home-head">Experience</h2>
    <Timeline items={experience} />
  </section>

  {/* ---- Education ---- */}
  <section id="education">
    <h2 class="home-head">Education</h2>
    <Timeline items={education} />
  </section>

  {/* ---- Teaching ---- */}
  <section id="teaching">
    <h2 class="home-head">Teaching</h2>
    <Timeline items={teaching} />
  </section>

  {/* ---- Activities & Service ---- */}
  <section id="service">
    <h2 class="home-head">Activities &amp; Service</h2>
    <Timeline items={activities} />
  </section>

  {/* ---- Honors & Awards (above Contact — closes the page on achievement) ---- */}
  <section id="honors">
    <h2 class="home-head">Honors &amp; Awards</h2>
    {
      honors.filter(entryVisible).map((g: { group: string; items: string[] }) => (
        <div class="honor-group">
          <div class="honor-group__label">{g.group}</div>
          <ul class="honor-group__list">
            {g.items.map((it: string) => (
              <li>
                <Markdown content={it} />
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>

  {/* ---- Contact ---- */}
  <section id="contact">
    <h2 class="home-head">Contact</h2>
    <p>
      I'm always up for a coffee chat about research, collaborations, internships, or wherever
      graphics meets design. <a
        href="#"
        class="say-hi"
        data-u={enc(mailUser)}
        data-d={enc(mailDomain)}>Say hi</a
      > anytime.
    </p>
  </section>
</Base>

<style>
  .profile__advisors {
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin-bottom: var(--space-4);
  }
  .profile__portrait {
    position: relative;
  }
  .profile__portrait .profile__photo {
    position: relative;
    z-index: 1;
  }
  /* "Say hi" — braced by the robot arm. As the arm rises into the footer
     (--arm → 1, set by the engine on :root), an accent underline draws in
     under the link so the eye lands on it. Reduced-motion: static full underline. */
  .say-hi {
    position: relative;
  }
  .say-hi::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.15em;
    height: 0.12em;
    background: var(--accent);
    transform: scaleX(var(--arm, 0));
    transform-origin: left center;
    transition: transform 0.4s var(--ease, ease);
    border-radius: 1px;
    opacity: 0.85;
  }
  @media (prefers-reduced-motion: reduce) {
    .say-hi::after {
      transform: scaleX(1);
      transition: none;
    }
  }
  .all-pubs {
    margin-top: var(--space-5);
  }
  .all-pubs > summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--step--1);
    color: var(--accent);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--hairline);
  }
  .all-pubs > summary::-webkit-details-marker {
    display: none;
  }
  .all-pubs[open] > summary {
    border-bottom: 1px solid var(--hairline);
    margin-bottom: var(--space-3);
  }
  @media (max-width: 640px) {
    .profile__portrait {
      order: -1;
    } /* photo first on mobile */
  }
</style>

---
import Base from '@/layouts/Base.astro';
import Markdown from '@/components/Markdown.astro';
import CompactPub from '@/components/CompactPub.astro';
import Socials from '@/components/Socials.astro';
import Timeline from '@/components/Timeline.astro';
import WorkProjectRow from '@/components/WorkProjectRow.astro';
import NewsList from '@/components/NewsList.astro';
import RobotLegs from '@/components/RobotLegs.astro';
import {
  site,
  researchInterests,
  getPapers,
  experience,
  education,
  honors,
  teaching,
  activities,
  newsItems,
  entryVisible,
} from '@/lib/data';
import { getCollection } from 'astro:content';

// One page = the whole CV. Scroll-only, no nav.
// `demo` papers (the unpublished example page's fictional entry) never appear
// in the live publications list — they're resolvable by citekey only.
const papers = getPapers().filter((p) => p.fields.demo !== 'true');
// `featured` (web-only, top of #publications) vs `selected` (PDF-only) in papers.bib — don't conflate.
const selectedPubs = papers.filter((p) => p.featured);
const otherPubs = papers.filter((p) => !p.featured);

// Projects = work/engineering only; category filter keeps 'research' in #publications.
const projects = (await getCollection('projects'))
  .filter((p) => p.data.category !== 'research')
  .sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0));

// News: newest first, 4 visible + the rest behind a "More news" toggle.
// From content/news.yaml (validated in lib/data.ts).
const allNews = [...newsItems].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const news = allNews.slice(0, 4);
const moreNews = allNews.slice(4);

// Join all statements so the bio can be multi-paragraph, not just the first.
const bio = researchInterests.statements.join('\n\n');

// "Say hi" email obfuscation (base64 halves, JS-decoded) — same as Socials.astro.
const [mailUser, mailDomain] = site.email.split('@');
const enc = (s: string) => Buffer.from(s, 'utf-8').toString('base64');
---

<Base>
  <section id="profile" class="profile">
    <div class="profile__text">
      <h1>{site.name}</h1>
      <p class="profile__role">
        {site.title} ·{' '}
        {
          site.department && site.department_url && (
            <Fragment>
              <a href={site.department_url}>{site.department}</a>,{' '}
            </Fragment>
          )
        }
        <a href={site.affiliation_url}>{site.affiliation}</a>
      </p>
      {
        site.advisors.length > 0 && (
          <p class="profile__advisors">
            Advised by{' '}
            {site.advisors.map((a, i) => (
              <Fragment>
                {i > 0 && (i === site.advisors.length - 1 ? ' & ' : ', ')}
                <a href={a.url}>{a.name}</a>
              </Fragment>
            ))}
          </p>
        )
      }
      <div class="profile__bio"><Markdown content={bio} /></div>
      <Socials />
    </div>
    <div class="profile__portrait">
      <img
        class="profile__photo"
        src="/profile-photo.webp"
        alt={`Portrait of ${site.name}`}
        width="336"
        height="420"
        loading="eager"
      />
      <RobotLegs zone="photo" />
    </div>
  </section>

  <section id="projects">
    <h2 class="home-head">Projects</h2>
    <div class="wcards">{projects.map((p) => <WorkProjectRow project={p} />)}</div>
  </section>

  <section id="publications">
    <h2 class="home-head">Publications</h2>
    <div class="cpubs">
      {selectedPubs.map((p) => <CompactPub paper={p} />)}
    </div>
    {
      otherPubs.length > 0 && (
        <details class="all-pubs">
          <summary>All publications ({otherPubs.length} more)</summary>
          <div class="cpubs">
            {otherPubs.map((p) => (
              <CompactPub paper={p} />
            ))}
          </div>
        </details>
      )
    }
  </section>

  <section id="news">
    <h2 class="home-head">News</h2>
    <NewsList items={news} />
    {
      moreNews.length > 0 && (
        <details class="all-news">
          <summary>More news ({moreNews.length} more)</summary>
          <NewsList items={moreNews} />
        </details>
      )
    }
  </section>

  <section id="experience">
    <h2 class="home-head">Experience</h2>
    <Timeline items={experience} />
  </section>

  <section id="education">
    <h2 class="home-head">Education</h2>
    <Timeline items={education} />
  </section>

  <section id="teaching">
    <h2 class="home-head">Teaching</h2>
    <Timeline items={teaching} />
  </section>

  {/* Honors — placed above Contact to close the page on achievement */}
  <section id="honors">
    <h2 class="home-head">Honors &amp; Awards</h2>
    {
      honors.filter(entryVisible).map((g: { group: string; items: string[] }) => (
        <div class="honor-group">
          <div class="honor-group__label">{g.group}</div>
          <ul class="honor-group__list">
            {g.items.map((it: string) => (
              <li>
                <Markdown content={it} />
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>

  <section id="service">
    <h2 class="home-head">Activities &amp; Service</h2>
    <Timeline items={activities} />
  </section>

  <section id="contact">
    <h2 class="home-head">Contact</h2>
    <p>
      I'm always up for a coffee chat about research, collaborations, internships, or wherever
      graphics meets design. <a
        href="#"
        class="say-hi"
        data-u={enc(mailUser)}
        data-d={enc(mailDomain)}>Say hi</a
      > anytime.
    </p>
  </section>
</Base>

<style>
  .profile__advisors {
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin-bottom: var(--space-4);
  }
  .profile__portrait {
    position: relative;
  }
  .profile__portrait .profile__photo {
    position: relative;
    z-index: 1;
  }
  /* "Say hi" underline: drawn in by the engine's --arm var (→1) as the arm rises.
     Reduced-motion: static full underline. */
  .say-hi {
    position: relative;
  }
  .say-hi::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.15em;
    height: 0.12em;
    background: var(--accent);
    transform: scaleX(var(--arm, 0));
    transform-origin: left center;
    transition: transform 0.4s var(--ease, ease);
    border-radius: 1px;
    opacity: 0.85;
  }
  @media (prefers-reduced-motion: reduce) {
    .say-hi::after {
      transform: scaleX(1);
      transition: none;
    }
  }
  .all-pubs,
  .all-news {
    margin-top: var(--space-5);
  }
  .all-pubs > summary,
  .all-news > summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--step--1);
    color: var(--accent);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--hairline);
  }
  .all-pubs > summary::-webkit-details-marker,
  .all-news > summary::-webkit-details-marker {
    display: none;
  }
  .all-pubs[open] > summary,
  .all-news[open] > summary {
    border-bottom: 1px solid var(--hairline);
    margin-bottom: var(--space-3);
  }
  @media (max-width: 640px) {
    .profile__portrait {
      order: -1;
    } /* photo first on mobile */
  }
</style>

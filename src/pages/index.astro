---
import Base from '@/layouts/Base.astro';
import Hero from '@/components/Hero.astro';
import Section from '@/components/Section.astro';
import NewsList from '@/components/NewsList.astro';
import Publications from '@/components/Publications.astro';
import { getCollection } from 'astro:content';
import BioContent from '../../content/about.typ?html&body';

const allNews = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestNews = allNews.slice(0, 5);
---
<Base>
  <Hero />

  <Section index="01" title="About">
    <div class="prose">
      <BioContent />
    </div>
  </Section>

  <Section index="02" title="News" meta={latestNews.length ? `${latestNews.length} latest` : ''} divider={true}>
    <NewsList items={latestNews} />
    {allNews.length > latestNews.length && (
      <a class="back-link" href="/news">All news →</a>
    )}
  </Section>

  <Section index="03" title="Publications" meta="all" divider={true}>
    <Publications />
  </Section>
</Base>

---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import { getCollection } from 'astro:content';

// Drafts are excluded from the public feed (draft: true) but still build at
// their own URL — the usage guide is reachable but not promoted as a post.
const posts = (await getCollection('blog')).filter((p) => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<Base title="Blog">
  <Section index="01" title="Blog" meta={`${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`}>
    {posts.length === 0 ? (
      <p class="empty-state">No posts yet - check back soon.</p>
    ) : (
      <ul class="blog-list">
        {posts.map((post) => (
          <li>
            <h3 class="blog-list__title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <div class="blog-list__meta">
              <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              {post.data.author && <span> · {post.data.author}</span>}
            </div>
            {typeof post.data.description === 'string' && post.data.description && <p class="blog-list__desc">{post.data.description}</p>}
          </li>
        ))}
      </ul>
    )}
  </Section>
</Base>

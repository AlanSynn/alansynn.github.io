---
import { existsSync } from 'node:fs';
import { getCollection } from 'astro:content';
import { getPaperByKey } from '@/lib/data';
import AcademicProject from '@/components/project/AcademicProject.astro';

// ACADEMIC project pages only (frontmatter `paper:` → research paper microsite).
// Work/engineering projects (no `paper:`) are served by their own STATIC route
// files (e.g. src/pages/projects/aka-musio-robot.astro). This split is what
// gives academic pages TRUE CSS isolation: this route imports ONLY
// AcademicProject → MicrositeShell → project-page.css (the verbatim microsite
// port), with NO site main.css/base.css in the graph. When both layouts shared
// one [slug] route, Astro bundled both stylesheets into every project page and
// the site's global element rules + colliding class names (.site-footer, .hero,
// .section, …) leaked into the microsite (serif headings, mono footer, 6% font
// upscale) — and CSS load order was nondeterministic, so it broke unpredictably.
// Separate routes = each page links only its own stylesheet. Load-order-safe.
export async function getStaticPaths() {
  const all = await getCollection('projects');
  // Drafts render in `just dev` only — filtered out of the production build so
  // they never ship to the live site (the unpublished example page uses this).
  const projects = import.meta.env.PROD ? all.filter((p) => !p.data.draft) : all;

  // Build-time integrity: a `paper:` citekey MUST resolve in papers.bib.
  const missingCitekeys = projects
    .filter((p) => p.data.paper && !getPaperByKey(p.data.paper))
    .map((p) => `projects/${p.id}.md → "${p.data.paper}"`);
  if (missingCitekeys.length > 0) {
    throw new Error(
      `[content] ${missingCitekeys.length} project(s) reference a paper citekey not found in content/papers.bib:\n  ` +
        missingCitekeys.join('\n  '),
    );
  }

  // Footgun guard: every NON-paper (work) project needs a matching static route
  // file in this directory, else it 404s. Fail the build with a precise message
  // instead of silently dropping the page. Use process.cwd() (project root) —
  // import.meta.url is rebased to the build chunk dir during `astro build`, so
  // it can't locate source files.
  const routeDir = `${process.cwd()}/src/pages/projects/`;
  const workWithoutRoute = projects
    .filter((p) => !p.data.paper)
    .filter((p) => !existsSync(`${routeDir}${p.id}.astro`));
  if (workWithoutRoute.length > 0) {
    throw new Error(
      `[routes] ${workWithoutRoute.length} work project(s) (no \`paper:\`) have no static route file.\n` +
        `  Since [slug].astro serves academic pages only, each work project needs its own\n` +
        `  src/pages/projects/<slug>.astro. Missing:\n  ` +
        workWithoutRoute.map((p) => `${p.id}.md`).join('\n  '),
    );
  }

  // PROD asset check: frontmatter image/video/src paths are free strings, so a
  // typo renders a broken image under a green build. Walks each entry for any
  // root-relative string and existsSync's it against public/. Skipped in dev so
  // a project page can be drafted before its assets land.
  if (import.meta.env.PROD) {
    const missing: string[] = [];
    const visit = (node: unknown, trail: string) => {
      if (typeof node === 'string') {
        if (
          node.startsWith('/') &&
          !node.startsWith('//') &&
          !existsSync(`${process.cwd()}/public${node}`)
        )
          missing.push(`${trail} → ${node}`);
      } else if (Array.isArray(node)) {
        node.forEach((c, i) => visit(c, `${trail}[${i}]`));
      } else if (node && typeof node === 'object') {
        for (const [k, v] of Object.entries(node as Record<string, unknown>))
          visit(v, trail ? `${trail}.${k}` : k);
      }
    };
    for (const p of projects) visit(p.data, `${p.id}.md`);
    if (missing.length) {
      throw new Error(
        `[content] ${missing.length} project asset path(s) do not resolve under public/ (would render a broken image/link). Add the asset or fix the path:\n  ` +
          missing.map((m) => `- ${m}`).join('\n  '),
      );
    }
  }

  return projects
    .filter((p) => p.data.paper)
    .map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
---

<AcademicProject project={project} />

---
import Base from '@/layouts/Base.astro';
import CouplerCurve from '@/components/CouplerCurve.astro';
import { site } from '@/lib/data';
---

<Base title="Not found" description="This page moved or never existed.">
  <div class="not-found">
    <div class="coupler-divider"><CouplerCurve /></div>
    <div class="not-found__code">404</div>
    <h1 class="not-found__title">Nothing here.</h1>
    <p class="not-found__text">This page moved, or never existed.</p>
    <a class="btn btn--primary" href="/">Back to {site.short_name}</a>
  </div>
</Base>

<style>
  .not-found {
    text-align: center;
    padding-block: var(--space-9);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }
  .not-found__code {
    font-family: var(--font-mono);
    font-size: var(--step-5);
    color: var(--accent);
    letter-spacing: var(--tracking-mono);
  }
  .not-found__title {
    font-size: var(--step-3);
  }
  .not-found__text {
    color: var(--ink-soft);
  }
</style>

---
// RobotLegs.astro — a pair of humanoid legs for the RobotIK engine. Two 3-DOF
// chains (hip/knee/ankle) per leg + a foot below the ankle. Links drawn +Y
// (root offset +π/2). Dangles below the portrait; walks with scroll + idle drift,
// foot tap, leans toward the cursor when pulled. Reduced-motion: inline rest pose.
//
// Geometry contract (must match RobotIK.astro): viewBox 0 0 140 260;
// hips (50,10)+(90,10); l1=92 → knee rest y=102; l2=86 → ankle rest y=188.
interface Props { zone?: string }
const { zone = 'photo' } = Astro.props;
const HIP_X = [50, 90];
const kneeY = 10 + 92;     // 102
const ankleY = kneeY + 86; // 188
---
<div class="robot-legs" data-rig="legs" data-zone={zone} aria-hidden="true">
  <svg viewBox="0 0 140 260" xmlns="http://www.w3.org/2000/svg">
    {/* pelvis bracket (visible at the top of the rig — the hips mount here) */}
    <path class="rl-pelvis"
      d="M 32 10 Q 32 3 39 3 L 101 3 Q 108 3 108 10 Q 108 17 101 17 L 39 17 Q 32 17 32 10 Z" />
    <circle class="rl-pelvis-dot" cx="70" cy="10" r="2.6" />

    {HIP_X.map((hx, i) => (
      <g class="leg" data-side={i === 0 ? 'l' : 'r'}>
        {/* hip: rotates around (hx,10) — thigh drawn +Y to knee (hx,102) */}
        <g class="j-hip" transform={`rotate(${i === 0 ? 5 : -5} ${hx} 10)`}>
          <line class="rl-link" x1={hx} y1="10" x2={hx} y2={kneeY} />
          <line class="rl-tendon" x1={hx - 3.5} y1="14" x2={hx - 3.5} y2={kneeY - 4} />
          <line class="rl-tendon" x1={hx + 3.5} y1="14" x2={hx + 3.5} y2={kneeY - 4} />
          <circle class="rl-joint" cx={hx} cy="10" r="4.4" />
          {/* knee: rotates around (hx,102) — shin drawn +Y to ankle (hx,188) */}
          <g class="j-knee" transform={`rotate(${i === 0 ? 11 : 10} ${hx} ${kneeY})`}>
            <line class="rl-link" x1={hx} y1={kneeY} x2={hx} y2={ankleY} />
            <line class="rl-tendon" x1={hx - 3.5} y1={kneeY + 4} x2={hx - 3.5} y2={ankleY - 4} />
            <line class="rl-tendon" x1={hx + 3.5} y1={kneeY + 4} x2={hx + 3.5} y2={ankleY - 4} />
            <circle class="rl-joint" cx={hx} cy={kneeY} r="3.8" />
            {/* ankle: rotates around (hx,188) — humanoid foot below the ankle */}
            <g class="j-ankle" transform={`rotate(${i === 0 ? 8 : 6} ${hx} ${ankleY})`}>
              {/* foot below the ankle — a downward peg that flares to a rounded sole.
                  Drawn along +Y so it renders pointing down at footAng ≈ π/2. */}
              <path class="rl-foot"
                d={`M ${hx - 3} ${ankleY} L ${hx - 4} ${ankleY + 8} Q ${hx - 4} ${ankleY + 18} ${hx} ${ankleY + 20} Q ${hx + 4} ${ankleY + 18} ${hx + 4} ${ankleY + 8} L ${hx + 3} ${ankleY} Z`} />
              <circle class="rl-heel" cx={hx} cy={ankleY + 15} r="1.5" />
              <circle class="rl-toetip" cx={hx} cy={ankleY + 22} r="1.3" />
            </g>
          </g>
        </g>
      </g>
    ))}

    {/* drag handles — engine repositions each frame at the solved foot tip + knee
        (knee drags as a pole vector). pointer-events:auto so they're grabbable
        even though the rig itself is pointer-events:none. Hidden when reduced. */}
    <circle class="handle h-leg-0-foot" data-drag="leg:0:foot" cx="50" cy="210" r="6" />
    <circle class="handle h-leg-0-knee" data-drag="leg:0:knee" cx="50" cy="102" r="5.5" />
    <circle class="handle h-leg-1-foot" data-drag="leg:1:foot" cx="90" cy="210" r="6" />
    <circle class="handle h-leg-1-knee" data-drag="leg:1:knee" cx="90" cy="102" r="5.5" />
  </svg>
</div>

<style>
  .robot-legs {
    color: var(--accent);
    position: absolute;
    left: 50%;
    top: 100%;               /* pelvis sits just below the photo (visible) */
    transform: translateX(-50%);
    width: 104px;
    margin-top: -6px;
    opacity: 0.6;
    z-index: 0;              /* behind .profile__photo (z:1) */
    pointer-events: none;
  }
  .robot-legs svg { width: 100%; height: auto; overflow: visible; display: block; }
  .rl-link {
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    fill: none;
  }
  .rl-pelvis {
    fill: var(--accent-soft);
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linejoin: round;
  }
  .rl-pelvis-dot { fill: currentColor; }
  .rl-tendon {
    stroke: currentColor;
    stroke-width: 0.85;
    stroke-linecap: round;
    stroke-dasharray: 2 3;
    fill: none;
    opacity: 0.45;
  }
  .rl-joint { fill: currentColor; }
  .rl-foot {
    fill: var(--accent-soft);
    stroke: currentColor;
    stroke-width: 1.3;
    stroke-linejoin: round;
  }
  .rl-heel { fill: currentColor; }
  .handle {
    fill: var(--paper);
    stroke: currentColor;
    stroke-width: 1.4;
    pointer-events: auto;
    cursor: grab;
    touch-action: none;
    opacity: 0.5;
    transition: opacity 0.2s var(--ease, ease);
  }
  .handle:hover { opacity: 1; }
  .handle:active { cursor: grabbing; }

  @media (max-width: 640px) {
    .robot-legs { display: none; }   /* portrait stacks; legs would collide */
  }
  @media (prefers-reduced-motion: reduce) {
    .handle { display: none; }       /* engine never runs → handles are inert */
  }
</style>

---
// NewsList.astro - renders news items (newest first, already capped by caller)
// from the content/news.yaml list. Body is markdown inline, rendered with
// `marked` to match the rest of the site's markdown-fragment output.
import { marked } from 'marked';
import type { NewsItem } from '@/lib/data';

marked.setOptions({ gfm: true, breaks: false });

interface Props { items: NewsItem[] }
const { items } = Astro.props;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', timeZone: 'UTC' });

// marked encodes `&` as &amp;; the prior Astro (remark) pipeline used the hex
// form &#x26;. Normalize so news output stays byte-identical to the old render().
// marked also leaves a trailing "\n" after <p>...</p>; strip it to match the
// tight `</p><a>` concatenation the old render() produced.
const renderBody = (s: string) =>
  (marked.parse(s) as string).replace(/&amp;/g, '&#x26;').replace(/\n+$/, '');
---
{items.length === 0 ? (
  <p class="empty-state">No news yet.</p>
) : (
  <ul class="news-list">
    {items.map((item) => (
      <li class:list={['news-item', { 'news-item--highlight': item.highlight }]}>
        <div class="news-item__date">{fmt(item.date)}</div>
        <div class="news-item__body">
          <Fragment set:html={renderBody(item.body)} />
          {item.link && (
            <a href={item.link} target="_blank" rel="noopener" aria-label="Related link">↗</a>
          )}
        </div>
      </li>
    ))}
  </ul>
)}

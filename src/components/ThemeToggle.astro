---
// Theme toggle button. Base.astro does the no-flash init; this flips + persists.
---

<button
  class="theme-toggle"
  id="theme-toggle"
  type="button"
  aria-label="Toggle light or dark theme"
  title="Toggle theme"
>
  <svg
    class="icon-sun"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"
    ></path>
  </svg>
  <svg
    class="icon-moon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>

<script is:inline>
  // Delegated listener on `document` so the toggle survives View-Transition
  // swaps: ClientRouter replaces the <button> element on every navigation, and
  // this is:inline IIFE only runs once (Astro dedupes it), so a handler bound
  // directly to #theme-toggle dies with the original element after one swap
  // (the toggle went inert after any project-page visit). `document` persists
  // across swaps, so a delegated click handler matches the button no matter how
  // many times it's replaced. Guard prevents double-registration.
  (function () {
    if (window.__themeToggleBound) return;
    window.__themeToggleBound = true;
    document.addEventListener('click', function (e) {
      var btn = e.target.closest && e.target.closest('#theme-toggle');
      if (!btn) return;
      var root = document.documentElement;
      var current = root.getAttribute('data-theme');
      if (!current) {
        current = 'light';
      }
      var next = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch (err) {}
    });
  })();
</script>

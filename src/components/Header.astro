---
// Site header: brand, primary nav, theme toggle. Sticky + blurred.
import { site } from '@/lib/data';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL; // '/'
const path = Astro.url.pathname;
const norm = (p: string) => (p.length > 1 && p.endsWith('/') ? p.slice(0, -1) : p);
const here = norm(path);

const isActive = (href: string): boolean => {
  if (href === '/') {
    return here === norm(base) || here === '';
  }
  const target = norm(base.replace(/\/$/, '') + href);
  return here === target || here.startsWith(target + '/');
};

const joinBase = (href: string) => (base.endsWith('/') ? base + href.replace(/^\//, '') : base + href);
---
<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href={base}>
      <span class="brand__mark">∴</span>
      <span>{site.short_name}</span>
    </a>
    <nav class="nav" aria-label="Primary">
      <a class="nav__link" href={base} aria-current={isActive('/') ? 'page' : undefined}>about</a>
      {site.nav.map((item: { label: string; href: string }) => (
        <a class="nav__link" href={joinBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
          {item.label.toLowerCase()}
        </a>
      ))}
    </nav>
    <div class="header-tools">
      <a class="header-search" href="/search" aria-label="Search" title="Search (Ctrl/⌘K)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

<script is:inline>
  // Ctrl/⌘K opens search.
  document.addEventListener('keydown', function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      window.location.href = '/search';
    }
  });
</script>

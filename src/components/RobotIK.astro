---
// RobotIK.astro — boots the real-time IK engine (src/scripts/robot-ik.ts), which
// solves closed-form IK (src/lib/ik.ts) per frame and writes `rotate()` onto SVG
// joint groups. One rAF loop, IntersectionObserver-gated; reduced-motion skips it
// (each rig ships a static rest pose). Two rigs: [data-rig="legs"] (hero) +
// [data-rig="arm"] (footer), both scroll-driven + drag-reactive.
//   End-effectors (foot/wrist/fingertip) = PULL (tracks pointer, springs back).
//   Mid-joints (knee/elbow) = DANGLE (distal chain rigid, blends back to IK solve).
//   Root rotates by (absAngle − rest): rest = first-link draw angle (+π/2 for +Y
//   chains, −π/2 for −Y, 0 for relative). Matches fkLeg/fk2 (DOM-FK test).
---

<script>
  // Lazy-load the engine off the critical path: IO when a rig nears the viewport,
  // else requestIdleCallback, else first user interaction. IO alone is fragile on
  // some scroll paths; the fallbacks cover mobile (rigs are display:none → IO never
  // fires). Reduced-motion: skip entirely.
  //
  // View-Transition re-init: Astro dedupes this module <script> so the IIFE runs
  // once, but every client-side nav swaps the [data-rig] nodes. Once the engine
  // is loaded we register a PERSISTENT `astro:page-load` listener on `document`
  // (which survives swaps) that re-runs init() — init() tears down the stale
  // instance and re-binds to the new rigs. Without this, returning to a page
  // with rigs (homepage/footer arm) after visiting another left them frozen at
  // the rest pose: the engine kept driving detached nodes. The gating below
  // applies only to the FIRST load (defer the import); re-inits are cheap.
  (function () {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const rigs = document.querySelectorAll('[data-rig]');
    if (!rigs.length) return;
    let engine: { init: () => void } | null = null;
    const reinit = () => {
      if (engine) engine.init();
    };
    let started = false;
    const gatingCleanup: Array<() => void> = [];
    const start = () => {
      if (started) return;
      started = true;
      while (gatingCleanup.length) gatingCleanup.pop()!();
      import('@/scripts/robot-ik').then((m) => {
        engine = m;
        m.init(); // first bind to this page's rigs
        document.addEventListener('astro:page-load', reinit); // re-bind on every VT nav
      });
    };
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries)
            if (e.isIntersecting) {
              start();
              break;
            }
        },
        { rootMargin: '300px' },
      );
      rigs.forEach((r) => io.observe(r));
      gatingCleanup.push(() => io.disconnect());
    }
    if ('requestIdleCallback' in window) requestIdleCallback(start, { timeout: 2200 });
    else setTimeout(start, 1400);
    ['pointerdown', 'wheel', 'scroll', 'touchmove', 'keydown'].forEach((ev) =>
      addEventListener(ev, start, { once: true, passive: true }),
    );
  })();
</script>

---
// RobotIK.astro — real-time IK engine for the mechanism motifs. Each frame solves
// closed-form IK (src/lib/ik.ts) for every rigged chain and writes `rotate()`
// transforms onto the SVG joint groups. One rAF loop, IntersectionObserver-gated;
// prefers-reduced-motion skips it entirely (each rig ships a static rest pose).
//
// Two rigs: [data-rig="legs"] (index) and [data-rig="arm"] (footer). Both are
// scroll-driven AND drag-reactive. End-effectors (foot tip, wrist, fingertip) use
// a PULL model: grab → chain target tracks the pointer; release → offset springs
// back to the scroll pose. Mid-joints (knee, elbow) use a DANGLE model: grab →
// tracks the pointer with the distal chain following rigidly; release → blends
// back to the IK solve (no discrete flip).
//
// Rigging convention: a chain's ROOT joint rotates by (absoluteAngle − rest),
// where rest is the angle its first link is drawn at (+π/2 for +Y-drawn chains
// like the legs, −π/2 for −Y-drawn chains like the arm + fingers, 0 for relative
// joints). Composes identically to fkLeg/fk2 — confirmed by the DOM-FK test.
---
<script>
  // Lazy-load the IK engine off the critical path. Dynamic-import it when a rig
  // is about to be seen — IntersectionObserver is the primary trigger (homepage
  // hero legs are in view at load → fires near-instantly). IO alone is fragile
  // (some layouts/scroll paths don't deliver late callbacks), so two fallbacks
  // also arm it: requestIdleCallback shortly after load, and the FIRST user
  // interaction (scroll/wheel/pointerdown/touchmove/key). On mobile the rigs are
  // display:none so the IO never fires, but an idle/interaction still loads the
  // engine for the hero legs. Reduced-motion: skip entirely (static rest pose).
  (function () {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const rigs = document.querySelectorAll('[data-rig]');
    if (!rigs.length) return;
    let done = false;
    const cleanup = [];
    const start = () => {
      if (done) return;
      done = true;
      cleanup.forEach((fn) => fn());
      import('@/scripts/robot-ik');
    };
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) if (e.isIntersecting) { start(); break; }
      }, { rootMargin: '300px' });
      rigs.forEach((r) => io.observe(r));
      cleanup.push(() => io.disconnect());
    }
    if ('requestIdleCallback' in window) requestIdleCallback(start, { timeout: 2200 });
    else setTimeout(start, 1400);
    ['pointerdown', 'wheel', 'scroll', 'touchmove', 'keydown'].forEach((ev) =>
      addEventListener(ev, start, { once: true, passive: true }),
    );
  })();
</script>

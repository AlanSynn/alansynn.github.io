---
// Markdown.astro â€” build-time markdownâ†’HTML for CV/project bodies (mixed content).
import { marked } from 'marked';

marked.setOptions({ gfm: true, breaks: false });

interface Props {
  content: string;
  class?: string;
}
const { content, class: cls = 'md' } = Astro.props;
const html = content ? (marked.parse(content) as string) : '';
---

{content ? <div class={cls} set:html={html} /> : null}

---
// MotionLeg.astro - a hidden-fun actuator/leg motif (sibling to CouplerCurve).
// A vertical pneumatic-style linear actuator: mounting base + cylinder body
// + gland/seal + piston rod + clevis (pivot end-effector). On scroll-into-
// view the rod telescopes out of the cylinder and the clevis settles with a
// tiny plant-wiggle. Both zones reuse ONE mechanism drawing — the photo zone
// simply rotates the SVG 180° so the bracket tucks behind the photo and the
// rod+clevis peek downward.
//
// zone="floor" (default): cylinder rests on the page floor, rod extends UP.
//                          Placed inside <footer>; the wrapper is a zero-size
//                          IntersectionObserver target there, the SVG is the
//                          fixed visual at the viewport bottom-left margin.
// zone="photo":            mounted under the profile photo, rod peeks DOWN.
//
// Reuses the site's free [data-reveal] IO (SiteChrome.astro). No new JS,
// no motion library, no layout shift (decorative + absolutely/fixed positioned).
interface Props { class?: string; zone?: 'photo' | 'floor' }
const { class: cls = '', zone = 'floor' } = Astro.props;
// Unique clip-path id so multiple instances on the same page don't collide.
const uid = 'ml-' + (crypto.randomUUID().slice(0, 8));
---
<div class:list={["motion-leg", `motion-leg--${zone}`, cls]} data-reveal aria-hidden="true">
  <svg class="motion-leg__svg" viewBox="0 0 80 220" fill="none" stroke="currentColor"
       stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <!-- Clip the rod+clevis to ABOVE the gland (y < 84). Retracted, the
           inner rod group is translated down into the cylinder body and is
           fully clipped away — true piston-emerge behavior on extend. -->
      <clipPath id={`${uid}-clip`} clipPathUnits="userSpaceOnUse">
        <rect x="0" y="0" width="80" height="84" />
      </clipPath>
    </defs>

    {/* === Static housing (anchored) ===================================== */}
    <g class="motion-leg__base" stroke-width="1.4">
      {/* Mounting plate (reads as floor base OR ceiling bracket when rotated) */}
      <rect x="18" y="196" width="44" height="14" rx="2" />
      <circle cx="28" cy="203" r="1.4" stroke-width="1" />
      <circle cx="52" cy="203" r="1.4" stroke-width="1" />
      {/* Boss connecting plate to cylinder bottom cap */}
      <line x1="40" y1="196" x2="40" y2="190" />
      {/* Cylinder bottom end cap (wider band) */}
      <rect x="14" y="184" width="52" height="6" rx="1.5" />
    </g>

    <g class="motion-leg__cylinder">
      {/* Main cylinder body */}
      <rect x="20" y="92" width="40" height="92" rx="5" stroke-width="1.6" />
      {/* Faint inner bore hint (the dashed centerline of the housing) */}
      <line x1="40" y1="100" x2="40" y2="176" stroke-width="0.7" stroke-dasharray="2 3" opacity="0.55" />
      {/* Pressure port — a small side nipple where a hose would attach.
           Reads pneumatic at a glance. */}
      <circle cx="20" cy="148" r="2" stroke-width="1" />
      <line x1="14" y1="148" x2="18" y2="148" stroke-width="1" />
      {/* Gland / seal at top of cylinder (where the rod exits) */}
      <rect x="17" y="84" width="46" height="8" rx="1.5" stroke-width="1.4" />
    </g>

    {/* === Extending group (rod + clevis) ================================ */}
    {/* Outer group holds the clip (in user-space, doesn't move).
         Inner group holds the animated translate. This split is what makes
         the piston-emerge read work — see comment in <defs>. */}
    <g class="motion-leg__rod-clip" clip-path={`url(#${uid}-clip)`}>
      <g class="motion-leg__rod">
        {/* Piston rod (polished), exits the gland upward */}
        <rect x="34" y="32" width="12" height="56" rx="1" stroke-width="1.4" />
        {/* Rod collar — small widening where rod meets the clevis */}
        <rect x="31" y="26" width="18" height="6" rx="1" stroke-width="1.2" />
        <g class="motion-leg__clevis">
          {/* Two prongs of the clevis (fork end) */}
          <line x1="30" y1="26" x2="30" y2="12" stroke-width="1.4" />
          <line x1="50" y1="26" x2="50" y2="12" stroke-width="1.4" />
          {/* Clevis cross-bar */}
          <line x1="30" y1="12" x2="50" y2="12" stroke-width="1.4" />
          {/* Pivot pin (the thing that would attach to a load) */}
          <circle cx="40" cy="18" r="3" stroke-width="1.2" />
          <circle cx="40" cy="18" r="1" stroke-width="0.8" />
        </g>
      </g>
    </g>
  </svg>
</div>

<style>
  /* Ancestor transform breaks inner position:fixed (floor zone). The wrapper
     is a pure IO target — strip its reveal transform, keep its opacity fade
     (so the SVG still fades in via inherited opacity). */
  .motion-leg[data-reveal] {
    transform: none !important;
  }

  .motion-leg__svg {
    color: var(--accent);
    display: block;
    overflow: visible;
  }

  /* --- Piston-emerge: clip (fixed, above-seal) + translate (animated) - */
  .motion-leg__rod {
    transform: translateY(80px);   /* retracted: rod group sits inside cylinder body, clipped away */
    transition: transform var(--dur-slow) cubic-bezier(0.34, 1.22, 0.5, 1);
    transition-delay: 120ms;
    will-change: transform;
  }
  .motion-leg.in .motion-leg__rod {
    transform: translateY(0);
  }

  /* Clevis settles with a tiny plant-wiggle after extension completes —
     the "foot planting" feel without being cartoonish. */
  .motion-leg__clevis {
    transform-origin: 40px 22px;
    transform-box: view-box;
  }
  .motion-leg.in .motion-leg__clevis {
    animation: ml-plant 540ms cubic-bezier(0.34, 1.45, 0.5, 1) 600ms 1 both;
  }
  @keyframes ml-plant {
    0%   { transform: rotate(0deg); }
    30%  { transform: rotate(2.4deg); }
    65%  { transform: rotate(-1.3deg); }
    100% { transform: rotate(0deg); }
  }

  /* ============== ZONE: PHOTO (peek from beneath profile photo) ====== */
  /* Wrapper is absolutely positioned within `.profile__portrait` (relative).
     The cylinder (top of rotated SVG) tucks up behind the photo (z:1); the
     rod + clevis dangle below into the empty space beneath the photo. */
  .motion-leg--photo {
    position: absolute;
    bottom: -92px;                /* rod + clevis (~92px) dangle below portrait */
    left: calc(50% - 42px);       /* center horizontally on the portrait (84px wide) */
    width: 84px;
    height: 220px;
    z-index: 0;                   /* behind the photo (photo is z:1) */
    pointer-events: none;
  }
  .motion-leg--photo .motion-leg__svg {
    width: 100%;
    height: 100%;
    transform: rotate(180deg);    /* flip: bracket up under photo, rod+clevis down */
    opacity: 0.6;
  }

  /* ============== ZONE: FLOOR (fixed, emerges from page floor) ======= */
  /* Wrapper is a zero-size IO trigger that lives inside <footer>; the SVG
     is the actual fixed visual pinned to the viewport bottom-LEFT margin
     (back-to-top lives bottom-RIGHT — opposite sides, no collision). */
  .motion-leg--floor {
    position: relative;
    width: 0;
    height: 0;
    overflow: visible;
  }
  .motion-leg--floor .motion-leg__svg {
    position: fixed;
    bottom: 0;
    left: clamp(0.5rem, 3vw, 2.5rem);
    width: 88px;
    height: 220px;
    z-index: 50;                  /* well under header(100), overlay(200), lightbox(300) */
    opacity: 0.5;
    pointer-events: none;
  }
  /* Hide where the viewport can't spare a left margin: below 980px the
     footer text spans the full width and the leg would overlap it. */
  @media (max-width: 980px) {
    .motion-leg--floor { display: none; }
  }

  /* Mobile: the stacked profile layout leaves no clean spot under the
     photo for the photo-zone leg. Keep the delight for wide screens. */
  @media (max-width: 640px) {
    .motion-leg--photo { display: none; }
  }

  /* ============== Reduced motion: clean static end-state ============= */
  /* The global nuke (base.css:16-24) already kills transitions/animations,
     but we explicitly plant the rod in its EXTENDED position so reduced-
     motion users see a fully-deployed actuator, not a frozen mid-stroke. */
  @media (prefers-reduced-motion: reduce) {
    .motion-leg__rod {
      transform: translateY(0) !important;
      transition: none !important;
    }
    .motion-leg__clevis,
    .motion-leg.in .motion-leg__clevis {
      animation: none !important;
    }
  }
</style>

---
// Timeline.astro — CV entry lists. Model: { period, title, location?, body(md),
// more(md)? }. `more` is CV/web-only detail the resume omits; the web mirrors
// the full CV, so body+more are concatenated here. Title may carry inline
// markdown (institution/advisor links).
import { marked } from 'marked';
import Markdown from './Markdown.astro';

interface Entry {
  period?: string;
  title: string;
  location?: string;
  body?: string;
  more?: string;
}
interface Props {
  items: Entry[];
}
const { items } = Astro.props;
const inline = (s: string) => (s ? (marked.parseInline(s) as string) : '');
---

<ul class="timeline">
  {
    items.map((e) => (
      <li class="timeline__item">
        {e.period && <div class="timeline__period">{e.period}</div>}
        <div>
          <div class="timeline__title" set:html={inline(e.title)} />
          {e.location && <span class="timeline__location">{e.location}</span>}
          {(e.body || e.more) && (
            <Markdown
              class="timeline__body"
              content={[e.body, e.more].filter(Boolean).join('\n\n')}
            />
          )}
        </div>
      </li>
    ))
  }
</ul>

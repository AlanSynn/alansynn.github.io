---
// Timeline.astro — renders CV entry lists (education, experience, teaching,
// activities). Entry model: { period, title, location?, body(markdown) }.
import Markdown from './Markdown.astro';

interface Entry {
  period?: string;
  title: string;
  location?: string;
  body?: string;
}
interface Props { items: Entry[]; }
const { items } = Astro.props;
---
<ul class="timeline">
  {items.map((e) => (
    <li class="timeline__item">
      {e.period && <div class="timeline__period">{e.period}</div>}
      <div>
        <div class="timeline__title">
          {e.title}
          {e.location && <span class="timeline__location">{e.location}</span>}
        </div>
        {e.body && <Markdown class="timeline__body" content={e.body} />}
      </div>
    </li>
  ))}
</ul>

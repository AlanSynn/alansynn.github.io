---
// LazyVideo.astro — lazy hover-to-play clip thumbnail. <video> starts src-less
// (nothing downloads until IO fires); resting frame is a separate <img> overlay.
interface Props {
  src: string;
  poster?: string;
  alt?: string;
  class?: string;
}
const { src, poster, alt, class: cls } = Astro.props;
---

<span class:list={['lazy-video', cls]}>
  <video
    muted
    loop
    playsinline
    preload="none"
    poster={poster}
    aria-label={alt}
    data-lazy-video
    data-src={src}></video>
  {
    poster && (
      <img class="lazy-video__poster" src={poster} alt="" loading="lazy" aria-hidden="true" />
    )
  }
</span>

<script is:inline>
  (function () {
    function init(root) {
      var scope = root || document;
      var vids = scope.querySelectorAll('video[data-lazy-video]:not([data-lazy-init])');
      if (!vids || !vids.length) return;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      for (var i = 0; i < vids.length; i++) {
        (function (v) {
          v.setAttribute('data-lazy-init', '');
          var src = v.getAttribute('data-src');
          if (!src) return;
          var wrap = v.closest('.lazy-video');
          var loaded = false;
          function setPlaying(on) {
            if (wrap) wrap.classList.toggle('is-playing', !!on);
          }
          // Lazy-load: set src only once near viewport.
          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(
              function (entries) {
                for (var k = 0; k < entries.length; k++) {
                  if (entries[k].isIntersecting && !loaded) {
                    loaded = true;
                    v.src = src;
                    v.load();
                    io.disconnect();
                  }
                }
              },
              { rootMargin: '200px' },
            );
            io.observe(v);
          } else {
            loaded = true;
            v.src = src;
            v.load();
          }
          if (!reduced) {
            // Hover-to-play (desktop); poster overlay is the resting frame.
            v.addEventListener('mouseenter', function () {
              if (!loaded) return;
              var p = v.play();
              if (p && p.catch)
                p.catch(function () {
                  /* ignore autoplay rejections */
                });
            });
            v.addEventListener('mouseleave', function () {
              if (!loaded) return;
              v.pause();
              try {
                v.currentTime = 0;
              } catch (e) {
                /* ignore */
              }
              setPlaying(false);
            });
            v.addEventListener('play', function () {
              setPlaying(true);
            });
            v.addEventListener('pause', function () {
              setPlaying(false);
            });
            v.addEventListener('ended', function () {
              setPlaying(false);
            });
          } else {
            // Reduced motion: tap to toggle play (no autoplay).
            v.addEventListener('click', function () {
              if (!loaded) return;
              if (v.paused) {
                var p = v.play();
                if (p && p.catch) p.catch(function () {});
              } else {
                v.pause();
              }
            });
            v.addEventListener('play', function () {
              setPlaying(true);
            });
            v.addEventListener('pause', function () {
              setPlaying(false);
            });
            v.addEventListener('ended', function () {
              setPlaying(false);
            });
          }
        })(vids[i]);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        init(document);
      });
    } else {
      init(document);
    }
    document.addEventListener('astro:page-load', function () {
      init(document);
    });
  })();
</script>

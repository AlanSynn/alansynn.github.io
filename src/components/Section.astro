---
// Section.astro - structural section wrapper with a mono section-head that
// encodes the index + title + optional meta. Numbering is justified: these
// sections (CV timeline, pubs-by-year) are real sequences.
import CouplerCurve from './CouplerCurve.astro';

interface Props {
  index?: string;        // e.g. "02"
  title: string;
  meta?: string;         // right-aligned mono caption
  id?: string;
  divider?: boolean;     // render coupler divider above
}
const { index, title, meta, id, divider = false } = Astro.props;
---
{divider && <div class="coupler-divider"><CouplerCurve /></div>}
<section class="section" id={id}>
  <header class="section-head">
    {index && <span class="section-head__index">§ {index}</span>}
    <h2 class="section-head__title">{title}</h2>
    {meta && <span class="section-head__meta">{meta}</span>}
  </header>
  <slot />
</section>

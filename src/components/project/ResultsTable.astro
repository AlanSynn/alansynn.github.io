---
// ResultsTable.astro — quantitative results OR ablation table. Semantic <table>
// with mono numerics, a highlighted best row (accent tint), caption + footnote.
// Renders the project's `results:` and `ablation:` frontmatter (same shape).
// On narrow viewports the table scrolls horizontally (data needs width).
// Classes are `ms-*` (scoped to the ported microsite design).
interface Props {
  columns: string[];
  rows: { cells: (string | number)[]; highlight?: boolean }[];
  caption?: string;
  note?: string;
}
const { columns, rows, caption, note } = Astro.props;
---

<div class="rtable" data-rtable>
  <table>
    {caption && <caption>{caption}</caption>}
    <thead>
      <tr>{columns.map((c) => <th scope="col">{c}</th>)}</tr>
    </thead>
    <tbody>
      {
        rows.map((r) => (
          <tr class:list={[{ 'is-best': r.highlight }]}>
            {r.cells.map((cell, i) => (
              <td class:list={[{ rtable__name: i === 0, rtable__num: i > 0 }]}>{cell}</td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
  {note && <p class="rtable__note">{note}</p>}
</div>

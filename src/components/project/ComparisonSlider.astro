---
// ComparisonSlider.astro — draggable before/after (or ours/baseline) image
// comparison. The graphics-paper money shot. Two stacked images; the "after"
// layer is clipped by a pointer-tracked divider. Keyboard: role="slider" with
// Arrow ←/→ (±2%), Home/End. Pointer + touch via pointer events. The divider is
// styled as a precision instrument: accent hairline + a mono % readout. Rendered
// by AcademicProject.astro from the project's `comparisons:` frontmatter.
// Classes are unprefixed (the academic shell is isolated, no site CSS to collide with); JS hooks use
// `data-cmp*` so it's class-agnostic + View-Transition-safe.
interface Side {
  src: string;
  alt: string;
}
interface Props {
  before: Side; // left/bottom layer
  after: Side; // right/top layer (clipped)
  labelBefore?: string;
  labelAfter?: string;
  caption?: string;
}
const { before, after, labelBefore = 'Before', labelAfter = 'After', caption } = Astro.props;
---

<figure class="cmp" data-cmp>
  <div
    class="cmp__stage"
    role="slider"
    tabindex="0"
    aria-label={`Comparison slider between ${labelBefore} and ${labelAfter}. Use left and right arrows to adjust.`}
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="50"
    data-cmp-stage
  >
    <img class="cmp__img cmp__img--before" src={before.src} alt={before.alt} loading="lazy" />
    <div class="cmp__clip" data-cmp-clip style="clip-path: inset(0 50% 0 0);">
      <img class="cmp__img cmp__img--after" src={after.src} alt={after.alt} loading="lazy" />
    </div>
    <span class="cmp__label cmp__label--before">{labelBefore}</span>
    <span class="cmp__label cmp__label--after">{labelAfter}</span>
    <div class="cmp__handle" data-cmp-handle aria-hidden="true">
      <span class="cmp__grip"></span>
      <span class="cmp__readout" data-cmp-readout>50%</span>
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script is:inline>
  // Pointer + keyboard comparison slider. No-op without [data-cmp]. Re-runs on
  // every Astro page-load (initial + View-Transition navigations) so the slider
  // wires on freshly swapped DOM. Old listeners die with removed nodes.
  (function () {
    document.addEventListener('astro:page-load', function () {
      var roots = document.querySelectorAll('[data-cmp]');
      if (!roots.length) return;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      roots.forEach(function (root) {
        if (root.dataset.cmpInit === '1') return;
        root.dataset.cmpInit = '1';
        var stage = root.querySelector('[data-cmp-stage]');
        var clip = root.querySelector('[data-cmp-clip]');
        var handle = root.querySelector('[data-cmp-handle]');
        var readout = root.querySelector('[data-cmp-readout]');
        if (!stage || !clip) return;
        var pos = 50; // percent

        function apply() {
          clip.style.clipPath = 'inset(0 ' + (100 - pos) + '% 0 0)';
          handle.style.left = pos + '%';
          stage.setAttribute('aria-valuenow', String(Math.round(pos)));
          if (readout) readout.textContent = Math.round(pos) + '%';
        }
        function fromClient(x) {
          var r = stage.getBoundingClientRect();
          pos = Math.min(100, Math.max(0, ((x - r.left) / r.width) * 100));
          apply();
        }

        var dragging = false;
        stage.addEventListener('pointerdown', function (e) {
          dragging = true;
          stage.setPointerCapture(e.pointerId);
          fromClient(e.clientX);
        });
        stage.addEventListener('pointermove', function (e) {
          if (dragging) fromClient(e.clientX);
        });
        stage.addEventListener('pointerup', function () {
          dragging = false;
        });
        stage.addEventListener('pointercancel', function () {
          dragging = false;
        });

        stage.addEventListener('keydown', function (e) {
          var k = e.key;
          if (k === 'ArrowLeft') {
            e.preventDefault();
            pos = Math.max(0, pos - 2);
            apply();
          } else if (k === 'ArrowRight') {
            e.preventDefault();
            pos = Math.min(100, pos + 2);
            apply();
          } else if (k === 'Home') {
            e.preventDefault();
            pos = 0;
            apply();
          } else if (k === 'End') {
            e.preventDefault();
            pos = 100;
            apply();
          }
        });

        stage.addEventListener('click', function (e) {
          if (dragging) return;
          fromClient(e.clientX);
        });

        if (!reduced) apply();
      });
    });
  })();
</script>

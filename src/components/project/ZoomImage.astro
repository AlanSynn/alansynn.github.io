---
// ZoomImage.astro — pointer-tracking magnifier lens (1.85×). Hover/pointer
// devices only — gated on matchMedia('(hover: hover)'), fully hidden on touch.
// Respects prefers-reduced-motion (lens stays hidden). Ported from the
// motionsmith standalone page's bespoke JS (no library). Rendered by
// AcademicProject.astro from the project's `system.zoom:` frontmatter.
interface Props {
  src: string;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---

<figure class="zoom-image" data-zoom-image>
  <div class="zoom-image__frame" data-zoom-frame={src}>
    <img src={src} alt={alt} loading="lazy" />
    <div class="zoom-image__lens" data-zoom-lens aria-hidden="true"></div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script is:inline>
  (function () {
    if (!window.matchMedia || !window.matchMedia('(hover: hover)').matches) return;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var frames = document.querySelectorAll('[data-zoom-frame]');
    if (!frames.length) return;
    var ZOOM = 1.85;
    frames.forEach(function (frame) {
      var lens = frame.querySelector('[data-zoom-lens]');
      var src = frame.getAttribute('data-zoom-frame');
      if (!lens || !src) return;
      lens.style.backgroundImage = "url('" + src + "')";
      lens.style.backgroundSize = ZOOM * 100 + '%';

      function move(e) {
        var r = frame.getBoundingClientRect();
        var x = e.clientX - r.left;
        var y = e.clientY - r.top;
        lens.style.left = x + 'px';
        lens.style.top = y + 'px';
        lens.style.backgroundPosition =
          ((x / r.width) * 100).toFixed(2) + '% ' + ((y / r.height) * 100).toFixed(2) + '%';
        if (!reduced) lens.style.opacity = '1';
      }
      frame.addEventListener('pointerenter', function () {
        frame.classList.add('is-zooming');
      });
      frame.addEventListener('pointermove', move);
      frame.addEventListener('pointerleave', function () {
        frame.classList.remove('is-zooming');
        lens.style.opacity = '0';
      });
    });
  })();
</script>

---
// SectionNav.astro — sticky horizontal section nav for academic project pages.
// `items` are the frontmatter `nav:` labels; hrefs slugify to match the markdown
// body's auto-generated <h2> ids (Astro slugifies headings: "Overview" → #overview).
// Scroll-spy (active = last section whose top crossed ~30% viewport) mirrors the
// proven Toc.astro approach. Mobile: hamburger disclosure ≤860px.
interface Props {
  items: string[];
}
const { items } = Astro.props;
const slug = (s: string) =>
  s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
const entries = items.map((label) => ({ label, href: '#' + slug(label) }));
---

{
  entries.length > 0 && (
    <nav class="proj-nav" aria-label="Sections" data-proj-nav>
      <ul class="proj-nav__list">
        {entries.map((e) => (
          <li>
            <a class="proj-nav__link" href={e.href} data-nav-target={e.href}>
              {e.label}
            </a>
          </li>
        ))}
      </ul>
      <details class="proj-nav__mobile" data-proj-nav-mobile>
        <summary>
          <span data-proj-nav-current>Sections</span>
          <svg viewBox="0 0 16 16" aria-hidden="true" width="14" height="14">
            <path
              d="M4 6l4 4 4-4"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </summary>
        <ul class="proj-nav__list proj-nav__list--mobile">
          {entries.map((e) => (
            <li>
              <a class="proj-nav__link" href={e.href} data-nav-target={e.href}>
                {e.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    </nav>
  )
}

<script is:inline>
  // Scroll-spy for the project section nav — mirrors Toc.astro's approach
  // (last section heading past 30% viewport is active), adapted for a horizontal
  // bar. Runs once on load; no-op if no [data-proj-nav] on the page.
  (function () {
    var nav = document.querySelector('[data-proj-nav]');
    if (!nav) return;
    var links = Array.prototype.slice.call(nav.querySelectorAll('[data-nav-target]'));
    if (!links.length) return;
    var targets = links
      .map(function (a) {
        var id = a.getAttribute('data-nav-target').slice(1);
        return { id: id, a: a };
      })
      .filter(function (t) {
        return document.getElementById(t.id);
      });
    if (!targets.length) return;
    var mobile = nav.querySelector('[data-proj-nav-mobile]');
    var currentLabel = nav.querySelector('[data-proj-nav-current]');
    var current = null;

    function setActive(id) {
      links.forEach(function (a) {
        var on = a.getAttribute('data-nav-target') === '#' + id;
        a.classList.toggle('is-active', on);
        if (on) a.setAttribute('aria-current', 'true');
        else a.removeAttribute('aria-current');
      });
      if (currentLabel) {
        var hit = targets.filter(function (t) {
          return t.id === id;
        })[0];
        if (hit) currentLabel.textContent = hit.a.textContent;
      }
    }
    function recompute() {
      var line = window.innerHeight * 0.3;
      var active = targets[0].id;
      for (var i = 0; i < targets.length; i++) {
        var el = document.getElementById(targets[i].id);
        if (!el) continue;
        if (el.getBoundingClientRect().top - 120 <= line) active = targets[i].id;
      }
      if (active !== current) {
        current = active;
        setActive(active);
      }
    }
    var ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(function () {
        recompute();
        ticking = false;
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    recompute();
    // Close mobile disclosure after a click so it won't cover the target.
    links.forEach(function (a) {
      a.addEventListener('click', function () {
        if (mobile && mobile.open) mobile.removeAttribute('open');
      });
    });
  })();
</script>

---
// Base.astro — document shell. Headerless (single-page CV); theme toggle replaces nav.
import '../styles/main.css';
import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle.astro';
import SiteChrome from '../components/SiteChrome.astro';
import RobotArm from '../components/RobotArm.astro';
import RobotIK from '../components/RobotIK.astro';
import { site, type Paper } from '@/lib/data';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  /* set false to render <main> without the centered container wrapper */
  contained?: boolean;
  /* present on academic paper pages → emit Google-Scholar citation_* meta and a
     ScholarlyArticle JSON-LD, and override OG/Twitter to the paper. */
  paper?: Paper;
}
const { title, description, wide = false, contained = true, paper } = Astro.props;

const pageTitle = title
  ? `${title} - ${site.short_name}`
  : (site.browser_title ?? `${site.name} · ${site.title}`);
const desc = description ?? paper?.abstract ?? site.description;
const year = new Date().getFullYear();

const sameAs = (site.socials ?? [])
  .map((s: { url: string }) => s.url)
  .filter((u: string) => !u.startsWith('mailto:'));

// Absolute-URL guard: pass through http(s)/protocol-relative URLs unchanged,
// prefix root-relative paths with the site origin. Avoids double-prefix if a
// field is ever absolute (e.g. an arXiv PDF).
const abs = (u?: string | null) =>
  u ? (/^(https?:)?\/\//.test(u) ? u : `${site.url}${u}`) : undefined;
const canonical = new URL(Astro.url.pathname, site.url).href;
// Scholar prefers YYYY/MM (or YYYY/MM/DD); fall back to bare year.
const citeDate =
  paper && paper.year && paper.month
    ? `${paper.year}/${String(paper.month).padStart(2, '0')}`
    : paper?.year
      ? String(paper.year)
      : undefined;

// ScholarlyArticle for paper pages; Person for everything else.
const jsonld = paper
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ScholarlyArticle',
      headline: paper.title,
      description: paper.abstract ?? undefined,
      ...(paper.preview ? { image: abs(paper.preview) } : {}),
      author: paper.authors.map((a) => ({
        '@type': 'Person',
        ...(a.given ? { givenName: a.given } : {}),
        familyName: a.family,
        name: a.given ? `${a.given} ${a.family}` : a.family,
      })),
      datePublished:
        paper.year && paper.month
          ? `${paper.year}-${String(paper.month).padStart(2, '0')}`
          : paper.year
            ? `${paper.year}`
            : undefined,
      isAccessibleForFree: true,
      ...(paper.fields.publisher
        ? { publisher: { '@type': 'Organization', name: paper.fields.publisher } }
        : {}),
      ...(paper.venue ? { isPartOf: { '@type': 'PublicationEvent', name: paper.venue } } : {}),
      ...(paper.doi ? { sameAs: `https://doi.org/${paper.doi}` } : {}),
    })
  : JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: site.name,
      jobTitle: site.title,
      url: site.url,
      image: `${site.url}/og.png`,
      worksFor: { '@type': 'Organization', name: site.affiliation },
      subjectOf: { '@type': 'WebSite', url: site.url },
      sameAs,
    });

// OG/Twitter: paper teaser (absolute) on paper pages, default og.png otherwise.
const ogTitle = paper ? paper.title : pageTitle;
// Default social image = MotionSmith teaser (plan §3.10), not a generic portrait.
const ogImage = abs(paper?.preview) ?? abs('/images/motionsmith/motionsmith-teaser.webp');
const ogType = paper ? 'article' : 'website';
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#1d4e89" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    {site.keywords?.length ? <meta name="keywords" content={site.keywords.join(', ')} /> : null}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:image" content={ogImage} />

    {/* Google-Scholar indexing (academic paper pages only). */}
    {
      paper && (
        <>
          <meta name="citation_title" content={paper.title} />
          {paper.authors.map((a) => (
            <meta name="citation_author" content={a.given ? `${a.family}, ${a.given}` : a.family} />
          ))}
          {citeDate && <meta name="citation_publication_date" content={citeDate} />}
          <meta name="citation_conference_title" content={paper.venue} />
          {paper.doi && <meta name="citation_doi" content={paper.doi} />}
          {paper.abstract && <meta name="citation_abstract" content={paper.abstract} />}
          {paper.pdf && <meta name="citation_pdf_url" content={abs(paper.pdf)} />}
        </>
      )
    }

    <link rel="canonical" href={canonical} />
    <ClientRouter />
    <script is:inline type="application/ld+json" set:html={jsonld} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.short_name} - Blog`}
      href="/rss.xml"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Hanken+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {/* Manrope — only on academic paper pages (the microsite port design). */}
    {
      paper && (
        <link
          href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
          rel="stylesheet"
        />
      )
    }
    <link
      rel="stylesheet"
      href="https://fred-wang.github.io/MathFonts/NewComputerModern/mathfonts.css"
    />

    <script is:inline>
      // No-flash theme init: resolve stored pref or system preference BEFORE paint.
      // `applyTheme` is also re-run on every View-Transition swap via the
      // persistent `astro:after-swap` listener below. Without that re-run, the
      // `data-theme` attribute (set here at runtime, not in the HTML source) is
      // lost when the ClientRouter swaps to/from the isolated MicrositeShell
      // (academic project pages — no theme script of their own), and the
      // `:root:not([data-theme])` + `prefers-color-scheme: dark` fallback in
      // tokens.css flips the site dark regardless of the stored choice. The
      // listener is registered once on first load and survives all client-side
      // navs (the ClientRouter keeps the same `document`), so it fires on every
      // swap — before paint, so there's no flash.
      (function () {
        document.documentElement.classList.remove('no-js'); // JS is on -> reveal animations active
        function applyTheme() {
          try {
            var t = localStorage.getItem('theme');
            if (!t) t = 'light'; // default to light
            document.documentElement.setAttribute('data-theme', t);
          } catch (e) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        }
        applyTheme();
        // Guard: the is:inline IIFE may re-run on some ClientRouter swap paths;
        // register the swap listener once so it can't accumulate. applyTheme is
        // idempotent regardless, but this keeps the listener list to one entry.
        if (!window.__themeListenerBound) {
          window.__themeListenerBound = true;
          document.addEventListener('astro:after-swap', applyTheme);
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main" class:list={[paper && 'main--project']} data-pagefind-body tabindex="-1">
      {
        contained ? (
          <div class:list={['container', wide && 'container--wide']}>
            <slot />
          </div>
        ) : (
          <slot />
        )
      }
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <a class="site-footer__copy" href="https://github.com/AlanSynn/alansynn.github.io#license"
          >© {year} {site.name}</a
        >
        <nav class="site-footer__path" aria-label="Site">
          <a href="/">{site.domain}</a>
          <span class="site-footer__sep" aria-hidden="true">/</span>
          <a href="/blog">blog</a>
        </nav>
        <ThemeToggle />
      </div>
      <RobotArm zone="floor" />
    </footer>
    <SiteChrome />
    <RobotIK />
  </body>
</html>

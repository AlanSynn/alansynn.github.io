---
// Base.astro — document shell. Headerless (single-page CV); theme toggle replaces nav.
import '../styles/main.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import SiteChrome from '../components/SiteChrome.astro';
import RobotArm from '../components/RobotArm.astro';
import RobotIK from '../components/RobotIK.astro';
import { site } from '@/lib/data';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  /* set false to render <main> without the centered container wrapper */
  contained?: boolean;
}
const { title, description, wide = false, contained = true } = Astro.props;

const pageTitle = title ? `${title} - ${site.short_name}` : `${site.name} · ${site.title}`;
const desc = description ?? site.description;
const year = new Date().getFullYear();

const sameAs = (site.socials ?? [])
  .map((s: { url: string }) => s.url)
  .filter((u: string) => !u.startsWith('mailto:'));
const jsonld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.title,
  url: site.url,
  image: `${site.url}/og.png`,
  worksFor: { '@type': 'Organization', name: site.affiliation },
  subjectOf: { '@type': 'WebSite', url: site.url },
  sameAs,
});
const canonical = new URL(Astro.url.pathname, site.url).href;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#1d4e89" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    {site.keywords?.length ? <meta name="keywords" content={site.keywords.join(', ')} /> : null}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content={`${site.url}/og.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${site.url}/og.png`} />

    <link rel="canonical" href={canonical} />
    <script is:inline type="application/ld+json" set:html={jsonld} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.short_name} - Blog`}
      href="/rss.xml"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Hanken+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fred-wang.github.io/MathFonts/NewComputerModern/mathfonts.css"
    />

    <script is:inline>
      // No-flash theme init: resolve stored pref or system preference BEFORE paint.
      (function () {
        document.documentElement.classList.remove('no-js'); // JS is on -> reveal animations active
        try {
          var t = localStorage.getItem('theme');
          if (!t) t = 'light'; // default to light
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main" data-pagefind-body tabindex="-1">
      {
        contained ? (
          <div class:list={['container', wide && 'container--wide']}>
            <slot />
          </div>
        ) : (
          <slot />
        )
      }
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <a class="site-footer__copy" href="https://github.com/AlanSynn/alansynn.github.io#license"
          >© {year} {site.name}</a
        >
        <nav class="site-footer__path" aria-label="Site">
          <a href={site.url}>{site.domain}</a>
          <span class="site-footer__sep" aria-hidden="true">/</span>
          <a href="/blog">blog</a>
        </nav>
        <ThemeToggle />
      </div>
      <RobotArm zone="floor" />
    </footer>
    <SiteChrome />
    <RobotIK />
  </body>
</html>

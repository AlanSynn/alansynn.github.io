@inproceedings{synn2026neuralcaustic,
  abbr={SIGGRAPH},
  title={NeuralCaustic: Inverse Caustic Design with Differentiable Optics},
  author={Synn, DoangJoo (Alan) and O'Brien, Morgan and Vega, Lucia},
  booktitle={ACM Transactions on Graphics (Proceedings of SIGGRAPH)},
  year={2026},
  month={7},
  publisher={ACM},
  address={Vancouver, Canada},
  preview={/images/example/teaser.svg},
  website={https://alansynn.com/projects/example-graphics},
  code={https://github.com/AlanSynn/example-graphics},
  video={/videos/motionsmith-demo.mp4},
  abstract={Designing caustic patterns — the bright curves focused by a refracting surface — has traditionally required expensive trial-and-error optimization. We present NeuralCaustic, a differentiable pipeline that inverts from a target image to the lens or reflector geometry that produces it. Our method pairs a differentiable ray tracer with a neural radiance prior, letting designers specify a desired light pattern and obtain a fabricable surface in seconds. We evaluate the approach on a gallery of target images and show that recovered surfaces reproduce the intended caustics under real-world illumination, with measurably lower error than prior optimization baselines. (This is a fictional template entry demonstrating the project-page system; not a real publication.)},
  demo={true},
  selected={false},
  featured={false}
}
